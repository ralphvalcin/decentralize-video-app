# Infura IPFS Configuration (Optional - for future decentralized features)
VITE_INFURA_PROJECT_ID=your_infura_project_id_here
VITE_INFURA_API_SECRET=your_infura_api_secret_here

# Development Configuration
VITE_SIGNALING_SERVER_URL=http://localhost:5001

# TURN Server — required for WebRTC NAT traversal in production
# Set these on your hosting provider (Render, Railway, etc.)
# Generate TURN_SECRET with: openssl rand -hex 32
TURN_SERVER_URL=your-turn-server-hostname-or-ip
TURN_SECRET=your-turn-shared-secret
# Optional secondary TURN server for redundancy
TURN_SERVER_URL_2=
TURN_SECRET_2=

# Chat encryption — master secret shared across all application instances.
# Per-room keys are derived internally from this secret and the room ID.
# All clients must use the same secret; mismatched secrets = decryption failures.
# Generate with: openssl rand -hex 32
VITE_CHAT_ENCRYPTION_SECRET=change-me-before-production